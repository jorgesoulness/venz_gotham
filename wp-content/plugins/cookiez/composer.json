{
  "name": "elementor/cookiez",
  "require": {
    "elementor/wp-notifications-package": "1.2.0",
    "elementor/wp-one-package": "1.0.62",
    "ext-json": "*"
  },
  "require-dev": {
    "dealerdirect/phpcodesniffer-composer-installer": "^0.7.1",
    "johnpbloch/wordpress-core": "^6.0",
    "squizlabs/php_codesniffer": "^3.13.5",
    "wp-coding-standards/wpcs": "3.3.0",
    "php-stubs/wordpress-stubs": "^6.0",
    "elementor/eunit": "^0.0.10",
    "phpcompatibility/phpcompatibility-wp": "^2.1",
    "phpunit/php-code-coverage": "^9.2",
    "wildwolf/wordpress-test-library-stubs": "^6.0",
    "wp-cli/i18n-command": "^2.2",
    "wp-phpunit/wp-phpunit": "^6.0",
    "yoast/phpunit-polyfills": "^2.0",
    "mockery/mockery": "^1.6"
  },
  "scripts": {
    "lint": "vendor/bin/phpcs --standard=./ruleset.xml",
    "lint:fix": "vendor/bin/phpcbf --standard=./ruleset.xml",
    "lint:report": "vendor/bin/phpcs --report=summary --standard=./ruleset.xml"
  },
  "config": {
    "allow-plugins": {
      "composer/installers": true,
      "dealerdirect/phpcodesniffer-composer-installer": true
    }
  },
  "repositories": [
    {
      "type": "vcs",
      "url": "git@github.com:elementor/eunit.git"
    },
    {
      "type": "composer",
      "url": "https://composer.elementor.com",
      "only": [
        "elementor/wp-one-package"
      ]
    }
  ]
}
